# Copy this file to `.env` and fill real values before first run.
# NEVER commit `.env`. Only `.env.example` is tracked (see .gitignore).

# ─── Database ───────────────────────────────────────────────────────
# Prisma connection string.
#
# Used for HOST-based commands only (e.g. `npm run db:studio`, ad-hoc scripts
# run outside Docker). Inside compose, every service OVERRIDES this via its
# `environment:` block (hostname becomes `postgres`, the compose service name).
#
# Host form uses the mapped port 54321 (compose.dev.yaml avoids host :5432
# conflicts with a local Postgres install).
DATABASE_URL=postgresql://foodie:foodie@localhost:54321/foodie?schema=public

# ─── API server ─────────────────────────────────────────────────────
# Port Express listens on. 3001 in dev; 3001 internal in prod (Caddy proxies).
API_PORT=3001

# Accepted browser origin for credentialed CORS (Better Auth cookies).
# Must match WEB_ORIGIN exactly; multiple origins not supported in v1.
WEB_ORIGIN=http://localhost:3000

# The web app's Next proxy hits the api via this URL for session checks.
# In dev: http://localhost:3001. In docker compose prod: http://api:3001.
API_INTERNAL_URL=http://localhost:3001

# ─── Better Auth ────────────────────────────────────────────────────
# REQUIRED in prod. Dev falls back to an insecure literal in apps/api/src/auth.ts —
# DO NOT ship that fallback to prod. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Canonical origin for the Better Auth baseURL + the Origin header the seed
# script sets. Must equal WEB_ORIGIN in dev.
BETTER_AUTH_URL=http://localhost:3000

# ─── Web app ────────────────────────────────────────────────────────
# Next.js rewrites /api/* here; NEXT_PUBLIC_API_URL is exposed to the browser.
# In dev: http://localhost:3001. In prod: the public https URL.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mapbox public token (pk.*). URL-restrict in the Mapbox dashboard to localhost +
# demo VPS hostname BEFORE demo day (Phase 5 / MAP-06 / DEMO-06). Never commit a
# real sk.* (secret) token — pre-commit hook blocks the prefix.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Storage ────────────────────────────────────────────────────────
# Image storage root inside the api container. compose.dev mounts a named volume;
# compose.prod bind-mounts /srv/foodie/images. path-traversal guard lives in
# apps/api/src/storage.ts safeResolve().
STORAGE_DIR=/var/data/images

# ─── Runtime ────────────────────────────────────────────────────────
# Set to "production" to enable Secure cookie flag + skip dev-only fallbacks.
NODE_ENV=development
