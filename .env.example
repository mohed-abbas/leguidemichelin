# Copy this file to `.env` and fill real values before first `docker compose up`.
# NEVER commit `.env`. Only `.env.example` is tracked (see .gitignore).

# ─── Postgres ────────────────────────────────────────────────
POSTGRES_USER=foodie
POSTGRES_PASSWORD=change_me_in_dev
POSTGRES_DB=foodie

# ─── Prisma / app connection strings ─────────────────────────
# Inside docker compose, use service name `postgres`. On host, use localhost:54321.
DATABASE_URL=postgresql://foodie:change_me_in_dev@postgres:5432/foodie?schema=public

# ─── Better Auth ─────────────────────────────────────────────
# BETTER_AUTH_SECRET must be a random 32+ char string.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_me_with_a_random_32_char_string
BETTER_AUTH_URL=http://localhost:3000

# ─── API ─────────────────────────────────────────────────────
API_PORT=3001
WEB_ORIGIN=http://localhost:3000

# ─── Web (Next.js) ───────────────────────────────────────────
# API_INTERNAL_URL is used by next.config.ts rewrites.
# In docker compose dev: http://api:3001
# On host (outside compose): http://localhost:3001
API_INTERNAL_URL=http://api:3001

# Optional: injected at build time for the footer commit-SHA badge
NEXT_PUBLIC_BUILD_SHA=dev
