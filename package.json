{
  "name": "guide-foodie-journey",
  "private": true,
  "version": "0.0.0",
  "description": "Guide Foodie Journey — Michelin-inspired souvenir PWA (hackathon).",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "docker compose -f compose.dev.yaml up",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "db:migrate:dev": "npm run migrate:dev --workspace=packages/db",
    "db:seed": "npm run seed --workspace=packages/db",
    "db:studio": "npm run studio --workspace=packages/db",
    "scrape:michelin": "npm run scrape --workspace=tools/scrape",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
