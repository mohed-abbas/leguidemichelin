generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Better Auth required models ────────────────────────────────────────
// Generated by `npx @better-auth/cli generate`; custom fields added per
// Better Auth `user.additionalFields` config in apps/api/src/auth.ts.

model User {
  id            String   @id @default(cuid())
  name          String                                  // Better Auth required
  email         String   @unique                        // Better Auth required
  emailVerified Boolean  @default(false)                // Better Auth required
  image         String?                                 // Better Auth required
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Custom fields (declared in Better Auth user.additionalFields)
  role         UserRole @default(DINER)
  totalPoints  Int      @default(0)
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])

  // Better Auth relations
  sessions Session[]
  accounts Account[]

  // Domain relations
  souvenirs    Souvenir[]
  pointTxns    PointTransaction[]
  redemptions  Redemption[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?                         // email/password credential
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ─── Domain enums ───────────────────────────────────────────────────────

enum UserRole {
  DINER
  RESTAURANT_STAFF
  ADMIN
}

enum MichelinRating {
  BIB
  ONE
  TWO
  THREE
}

enum PointSource {
  SOUVENIR_MINT
  REDEMPTION
}

// ─── Domain models (v1 scope — NO Journey/Badge per D-07) ──────────────

model Restaurant {
  id             String         @id @default(cuid())
  michelinSlug   String         @unique                // stable key for scrape upsert
  slug           String         @unique                // SEO-friendly
  name           String
  city           String
  address        String
  lat            Decimal        @db.Decimal(9, 6)
  lng            Decimal        @db.Decimal(9, 6)
  michelinRating MichelinRating
  cuisine        String?
  heroImageKey   String?                               // storage.ts opaque key
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  dishes    Dish[]
  souvenirs Souvenir[]
  staff     User[]                                     // staff-per-restaurant 1:N

  @@index([city])
  @@index([michelinRating])
}

model Dish {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  priceCents      Int                                  // D-05: Int cents
  defaultImageKey String?                              // storage.ts opaque key
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  souvenirs Souvenir[]

  @@index([restaurantId])
}

model Souvenir {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId    String
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id])
  dishId           String
  dish             Dish     @relation(fields: [dishId], references: [id])
  note             String?                             // ≤280 chars enforced by Zod
  imageKey         String                              // storage.ts opaque key
  usedDefaultImage Boolean  @default(false)
  pointsAwarded    Int
  createdAt        DateTime @default(now())

  pointTransactions PointTransaction[]                 // back-relation from ledger

  @@index([userId, createdAt])
  @@index([restaurantId])
}

model PointTransaction {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta        Int                                     // +mint, -redemption
  source       PointSource
  souvenirId   String?
  souvenir     Souvenir?   @relation(fields: [souvenirId], references: [id])
  redemptionId String?
  redemption   Redemption? @relation(fields: [redemptionId], references: [id])
  createdAt    DateTime    @default(now())

  @@index([userId, createdAt])
}

model Reward {
  id           String   @id @default(cuid())
  title        String
  description  String?
  pointsCost   Int
  imageKey     String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  redemptions Redemption[]
}

model Redemption {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardId    String
  reward      Reward   @relation(fields: [rewardId], references: [id])
  code        String   @unique                        // mock code
  pointsSpent Int
  createdAt   DateTime @default(now())

  pointTransactions PointTransaction[]                // back-relation

  @@index([userId, createdAt])
}
