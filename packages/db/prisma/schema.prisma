generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Better Auth required models ────────────────────────────────────────
// Generated by `npx @better-auth/cli generate`; custom fields added per
// Better Auth `user.additionalFields` config in apps/api/src/auth.ts.

model User {
  id            String   @id @default(cuid())
  name          String // Better Auth required
  email         String   @unique // Better Auth required
  emailVerified Boolean  @default(false) // Better Auth required
  image         String? // Better Auth required
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Custom fields (declared in Better Auth user.additionalFields)
  role         UserRole    @default(DINER)
  totalPoints  Int         @default(0)
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  disabledAt   DateTime? // D-06: null = active; admin soft-disable

  // Better Auth relations
  sessions Session[]
  accounts Account[]

  // Domain relations
  souvenirs   Souvenir[]
  pointTxns   PointTransaction[]
  redemptions Redemption[]
  reviews     Review[]
  favorites   Favorite[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String? // email/password credential
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ─── Domain enums ───────────────────────────────────────────────────────

enum UserRole {
  DINER
  RESTAURANT_STAFF
  ADMIN
}

enum MichelinRating {
  BIB
  ONE
  TWO
  THREE
}

enum PointSource {
  SOUVENIR_MINT
  REDEMPTION
  REVIEW_BONUS
}

// ─── Domain models (v1 scope — NO Journey/Badge per D-07) ──────────────

model Restaurant {
  id             String         @id @default(cuid())
  michelinSlug   String         @unique // stable key for scrape upsert
  slug           String         @unique // SEO-friendly
  name           String
  city           String
  address        String
  lat            Decimal        @db.Decimal(9, 6)
  lng            Decimal        @db.Decimal(9, 6)
  michelinRating MichelinRating
  cuisine        String?
  description    String? // short blurb shown on the diner restaurant detail page
  heroImageKey   String? // storage.ts opaque key
  disabledAt     DateTime? // D-06: null = visible publicly; non-null = admin-only
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  dishes    Dish[]
  souvenirs Souvenir[]
  staff     User[] // staff-per-restaurant 1:N
  reviews   Review[]
  favorites Favorite[]

  @@index([city])
  @@index([michelinRating])
  @@index([lat, lng]) // Phase 3: bbox map query
}

model Dish {
  id              String     @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  priceCents      Int // D-05: Int cents
  defaultImageKey String? // storage.ts opaque key
  sortOrder       Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  souvenirs Souvenir[]

  @@index([restaurantId])
}

model Souvenir {
  id               String     @id @default(cuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId     String
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id])
  dishId           String
  dish             Dish       @relation(fields: [dishId], references: [id])
  note             String? // ≤280 chars enforced by Zod
  imageKey         String // storage.ts opaque key
  usedDefaultImage Boolean    @default(false)
  pointsAwarded    Int
  createdAt        DateTime   @default(now())

  pointTransactions PointTransaction[] // back-relation from ledger
  review            Review?

  @@index([userId, createdAt])
  @@index([restaurantId])
}

model PointTransaction {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta        Int // +mint, -redemption
  source       PointSource
  souvenirId   String?
  souvenir     Souvenir?   @relation(fields: [souvenirId], references: [id])
  redemptionId String?
  redemption   Redemption? @relation(fields: [redemptionId], references: [id])
  reviewId     String?
  review       Review?     @relation(fields: [reviewId], references: [id])
  createdAt    DateTime    @default(now())

  @@index([userId, createdAt])
}

model Reward {
  id          String   @id @default(cuid())
  title       String
  description String?
  pointsCost  Int
  imageKey    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redemptions Redemption[]
}

model Redemption {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardId    String
  reward      Reward   @relation(fields: [rewardId], references: [id])
  code        String   @unique // mock code
  pointsSpent Int
  createdAt   DateTime @default(now())

  pointTransactions PointTransaction[] // back-relation

  @@index([userId, createdAt])
}

// ─── Review ─────────────────────────────────────────────────────────────
// Post-scan questionnaire tied to a restaurant visit. 6 fixed questions,
// each rated 1-3 (Michelin-flower scale). Optional 1:1 link to the Souvenir
// minted in the same visit. Submitting a review awards a bonus point logged
// in the PointTransaction ledger with source=REVIEW_BONUS.

model Review {
  id               String     @id @default(cuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId     String
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id])
  souvenirId       String?    @unique // one review per souvenir (when linked)
  souvenir         Souvenir?  @relation(fields: [souvenirId], references: [id])

  // 1-3 ratings for the 6 Figma questions
  productsQuality  Int // "Les produits étaient-ils de qualité ?"
  cookingAccuracy  Int // "Les cuissons étaient-elles justes ?"
  worthTheVisit    Int // "L'expérience valait-elle le détour ?"
  experienceSmooth Int // "L'expérience était-elle fluide ?"
  valueForMoney    Int // "Le rapport qualité-prix te semble-t-il correct ?"
  consistency      Int // "L'expérience était-elle cohérente du début à la fin ?"

  bonusPointsAwarded Int      @default(1)
  createdAt          DateTime @default(now())

  pointTransactions PointTransaction[] // back-relation

  @@index([userId, createdAt])
  @@index([restaurantId])
}

// ─── Favorite ───────────────────────────────────────────────────────────
// Phase 04.1 — Diner favorites a restaurant for quick recall. Composite
// unique on (userId, restaurantId) prevents duplicate rows; cascade on
// both FKs ensures no orphan rows referencing deleted users/restaurants.

model Favorite {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, restaurantId])
  @@index([userId])
  @@map("favorite")
}
