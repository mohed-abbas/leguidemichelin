# syntax=docker/dockerfile:1.7

# ─── Base ──────────────────────────────────────────
FROM node:22-alpine AS base
WORKDIR /workspace
RUN apk add --no-cache libc6-compat
RUN corepack disable && npm i -g npm@10

# ─── Dev ───────────────────────────────────────────
FROM base AS dev
ENV NODE_ENV=development
# Source mounted by compose; no COPY here.
EXPOSE 3000
CMD ["npm", "run", "dev", "--workspace=apps/web"]

# ─── Builder ───────────────────────────────────────
FROM base AS builder
# Install with NODE_ENV unset so devDeps (tsc, @types/*, tailwind, eslint) land.
# Runtime stage re-installs with --omit=dev.

# Workspace manifests for layer-caching
COPY package.json package-lock.json ./
COPY apps/api/package.json apps/api/
COPY apps/web/package.json apps/web/
COPY packages/db/package.json packages/db/
COPY packages/shared-schemas/package.json packages/shared-schemas/
COPY packages/tokens/package.json packages/tokens/
COPY packages/config/package.json packages/config/
COPY tools/scrape/package.json tools/scrape/

# --ignore-scripts skips packages/db's postinstall (`prisma generate`) — the
# schema isn't in the context yet. We run `npm run generate` after COPY below.
RUN npm ci --workspaces --include-workspace-root --ignore-scripts

# Source
COPY . .

# Generate Prisma client (web transitively imports @repo/db types) + build Next
RUN npm run generate --workspace=packages/db \
 && NODE_ENV=production npm run build --workspace=apps/web

# ─── Runtime ───────────────────────────────────────
FROM base AS runtime
ENV NODE_ENV=production
WORKDIR /app

COPY --from=builder /workspace/package.json /workspace/package-lock.json ./
COPY --from=builder /workspace/apps/web/package.json ./apps/web/
COPY --from=builder /workspace/packages/tokens/package.json ./packages/tokens/
COPY --from=builder /workspace/packages/shared-schemas/package.json ./packages/shared-schemas/

RUN npm ci --omit=dev --workspaces --include-workspace-root --ignore-scripts

COPY --from=builder /workspace/apps/web/.next ./apps/web/.next
COPY --from=builder /workspace/apps/web/public ./apps/web/public
COPY --from=builder /workspace/apps/web/next.config.ts ./apps/web/next.config.ts
COPY --from=builder /workspace/packages/tokens ./packages/tokens
COPY --from=builder /workspace/packages/shared-schemas/dist ./packages/shared-schemas/dist
COPY --from=builder /workspace/node_modules ./node_modules

EXPOSE 3000
CMD ["npm", "run", "start", "--workspace=apps/web"]
