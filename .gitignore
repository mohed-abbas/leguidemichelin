# Node
node_modules/
.npm/
npm-debug.log*

# Build outputs
dist/
build/
.next/
out/
coverage/
*.tsbuildinfo

# Prisma generated client (regenerated on install)
packages/db/node_modules/.prisma/
packages/db/src/generated/

# Env — NEVER commit real env files. .env.example IS committed.
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Docker build cache (local only; actual layers live in docker daemon)
.docker/

# Playwright
playwright-report/
test-results/
tools/scrape/.cache/
.playwright-mcp/

# Images written at runtime by storage.ts (Phase 4+); never commit
/var/data/images/

# Per-dev task briefs (ILIA-TASKS.md, MURX-TASKS.md, WILSON-TASKS.md, etc.)
*-TASKS.md

# Local-only manual test matrix (not committed)
scripts/admin-test-matrix.md

# Ad-hoc screenshots / debug artifacts left at repo root
/phase-*.png
/screenshot-*.png
